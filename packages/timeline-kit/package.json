    "@x-icons/tailwind-config": "workspace:^",
    "@x-icons/typescript-config": "workspace:^",
    "jsdom": "^28.1.0",
    "motion": "^12.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "5.9.2",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
