{
  "name": "x-icons",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev test:watch icons:watch --filter=web --filter=@x-icons/motion-kit --filter=@x-icons/timeline-kit --parallel --continue",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "test": "turbo run test --filter=web",
    "test:web": "turbo run test --filter=web",
    "test:web:watch": "turbo run test:watch --filter=web",
    "test:motion-kit": "turbo run test --filter=motion-kit",
    "test:motion-kit:watch": "turbo run test:watch --filter=motion-kit",
    "dev:timeline-kit": "turbo run dev --filter=@x-icons/timeline-kit --continue",
    "test:timeline-kit": "turbo run test:watch test:e2e:ui --filter=@x-icons/timeline-kit --parallel --continue",
    "build:timeline-kit": "turbo run build --filter=@x-icons/timeline-kit",
    "check-types:timeline-kit": "turbo run check-types --filter=@x-icons/timeline-kit",
    "check-types": "turbo run check-types",
    "icons:sync": "turbo run icons:sync --filter=web",
    "icons:watch": "turbo run icons:watch --filter=web"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.11",
    "typescript": "5.9.2",
    "ultracite": "7.2.4",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint",
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  }
}
